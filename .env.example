# Copy to .env and fill. NEVER commit .env (constitution: no committed secrets).

# Only required for gated/non-commercial models (e.g. FLUX.1-Fill-dev). Leave empty
# for the default SDXL inpainting + anime-face-seg + open_clip stack.
HUGGING_FACE_HUB_TOKEN=

# LoRA checkpoints for the inpaint UNet, trained by scripts/train_inpaint_lora.py.
# Each adapter must match the base MODEL_ID it was trained on.
#
# Single default adapter for the `base` checkpoint:
# LORA_PATH=/data/models/lora/step-2000
#
# Multiple selectable checkpoints — LORAS keys must match MODELS keys (below). The
# user picks one per edit via the `model` field of POST /api/v1/edits; GET
# /api/v1/models lists them. Same base id can appear under several keys.
# LORAS={"smile-v1":"/data/models/lora/smile-v1/step-2000","smile-v2":"/data/models/lora/smile-v2/step-3000"}
# LORA_FUSE=false   # true bakes LoRA into weights (faster inference, can't unload)

# --- Study workspace (feature 002) --------------------------------------------
# Postgres credentials (used by the postgres service and the backend DATABASE_URL).
POSTGRES_USER=flex
POSTGRES_PASSWORD=flex
POSTGRES_DB=flex
# Override if pointing the backend at an external database.
# DATABASE_URL=postgresql+psycopg://flex:flex@postgres:5432/flex

# Named-model registry as JSON {key: model_id_or_path}. docker-compose.yml registers
# base + a finetuned slot by default; override here to add/replace models.
# To register LoRA checkpoints sharing the base, add same-base keys here and map
# each key's adapter dir in LORAS above:
# MODELS={"base":"diffusers/stable-diffusion-xl-1.0-inpainting-0.1","smile-v1":"diffusers/stable-diffusion-xl-1.0-inpainting-0.1","smile-v2":"diffusers/stable-diffusion-xl-1.0-inpainting-0.1"}
